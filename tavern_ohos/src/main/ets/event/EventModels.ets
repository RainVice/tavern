/**
 * 描述事件目录事件发布时携带的数据结构，
 * 用于在应用/服务启动完成后通知各模块或插件，表明运行时已完成初始化并可接收后续事件。
 */
export interface ServerStartedPayload {
  /**
   * 事件来源标识，例如 'system'、'user' 或 'plugin'，
   * 用于区分启动事件的发起方，便于插件系统和宿主追踪触发链。
   */
  source: string;
}

/**
 * 描述事件目录事件发布时携带的数据结构，
 * 用于在运行时发生状态变更（如启动完成、停止、发生错误）时向监听方发送信号。
 */
export interface RuntimeSignalPayload {
  /**
   * 运行时信号标识，例如 'start'、'stop'、'error'，
   * 用于告知监听方运行时当前处于哪个生命周期阶段或遇到了何种异常。
   */
  signal: string;
  /**
   * 信号附带的结构化详情，
   * 用于携带信号相关的补充信息（如错误堆栈、启动耗时等），供监听方处理。
   */
  detail: string;
}

/**
 * 描述事件目录持久化或内存索引中的一条记录，
 * 用于注册系统内部所有可发布事件的元数据，供插件发现、UI 展示和事件路由使用。
 */
export interface EventCatalogEntry {
  /**
   * 事件在系统内注册的规范名称，例如 'app.ready'，
   * 作为事件在 EventBus 上发布/订阅时的唯一标识，供内部模块按名称查找和转发。
   */
  name: string;
  /**
   * 向上游（外部插件/扩展）映射时使用的名称，
   * 用于将内部事件名称转换为外部插件系统可以识别的事件名，实现插件兼容性。
   */
  upstreamName: string;
  /**
   * 事件归属的业务领域，例如 'app'、'chat'、'message'，
   * 用于对事件进行分类管理和按领域筛选，方便插件只监听感兴趣的事件域。
   */
  domain: string;
  /**
   * 事件发布时可携带的字段名称列表，
   * 用于告知入站插件和 UI 层该事件载荷中包含哪些字段，辅助事件文档生成和类型验证。
   */
  payloadFields: Array<string>;
  /**
   * 是否对插件系统可见（暴露给上游调用方），
   * 用于控制该事件是否可通过外部插件 API 被订阅或发布，实现事件访问控制。
   */
  pluginVisible: boolean;
  /**
   * 是否对 UI 层可见（展示在事件管理界面），
   * 用于控制该事件是否出现在事件监控/管理界面中，帮助开发者调试。
   */
  uiVisible: boolean;
}

/**
 * 描述事件目录事件发布时携带的数据结构，
 * 用于在宿主或其他模块查询/发布事件目录条目时传递事件元数据和附带描述。
 */
export interface EventCatalogPayload {
  /**
   * 事件目录中对应的事件条目，
   * 用于向事件的监听方传递该事件的注册元数据，供路由和处理决策使用。
   */
  entry: EventCatalogEntry;
  /**
   * 事件附带的操作或状态描述信息，
   * 用于说明本次事件发布的具体上下文，例如发布原因或关联的状态变更内容。
   */
  detail: string;
}
